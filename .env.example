# Local LibreOffice conversion service (Word↔PDF)
# See services/word-to-pdf/.env.example

# iLovePDF API credentials — used ONLY by the serverless function in /api/compress.js.
# Set these in your Vercel project (Settings → Environment Variables).
# NEVER commit real values; the secret key must stay server-side.
ILOVEPDF_PUBLIC_KEY=your_project_public_key_here
ILOVEPDF_SECRET_KEY=your_secret_key_here
