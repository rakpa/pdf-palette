# iLovePDF API — https://developer.ilovepdf.com/user/projects
# Public key is exposed to the browser (required for client-side iLovePDF auth).
VITE_ILOVEPDF_PUBLIC_KEY=your_project_public_key

# Secret key — only needed for server-side admin APIs (not used by compress).
ILOVEPDF_SECRET_KEY=your_secret_key
